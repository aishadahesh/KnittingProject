  "texture_control_groups": [
    {
      "title": "Scale and direction",
      "controls": [
        {
          "key": "texture_scale_x",
          "label": "Scale X",
          "min": 0.25,
          "max": 4.0,
          "format": "%.2f"
        },
        {
          "key": "texture_scale_y",
          "label": "Scale Y",
          "min": 0.25,
          "max": 4.0,
          "format": "%.2f"
        },
        {
          "key": "texture_chevron_angle",
          "label": "Chevron angle",
          "min": -1.57,
          "max": 1.57,
          "format": "%.2f rad"
        }
      ]
    },
    {
      "title": "Fibers and roughness",
      "controls": [
        {
          "key": "texture_ridge_strength",
          "label": "Stitch ridge depth",
          "min": 0.0,
          "max": 1.0,
          "format": "%.2f"
        },
        {
          "key": "texture_ridge_scale",
          "label": "Stitch ridge spacing",
          "min": 1.0,
          "max": 24.0,
          "format": "%.1f"
        },
        {
          "key": "texture_fiber_strength",
          "label": "Fiber streak depth",
          "min": 0.0,
          "max": 1.0,
          "format": "%.2f"
        },
        {
          "key": "texture_fiber_scale",
          "label": "Fiber streak spacing",
          "min": 4.0,
          "max": 80.0,
          "format": "%.1f"
        },
        {
          "key": "texture_fiber_sharpness",
          "label": "Fiber sharpness",
          "min": 0.35,
          "max": 4.0,
          "format": "%.2f"
        },
        {
          "key": "texture_noise_strength",
          "label": "Uneven roughness",
          "min": 0.0,
          "max": 1.0,
          "format": "%.2f"
        }
      ]
    },
    {
      "title": "Stitch shadows",
      "controls": [
        {
          "key": "texture_groove_darkness",
          "label": "Dark groove depth",
          "min": 0.0,
          "max": 1.0,
          "format": "%.2f"
        },
        {
          "key": "texture_center_shadow",
          "label": "Center crease shadow",
          "min": 0.0,
          "max": 1.0,
          "format": "%.2f"
        }
      ]
    },
    {
      "title": "Gloss",
      "controls": [
        {
          "key": "texture_gloss_strength",
          "label": "Gloss strength",
          "min": 0.0,
          "max": 2.0,
          "format": "%.2f"
        },
        {
          "key": "texture_highlight_width",
          "label": "Highlight width",
          "min": 0.0,
          "max": 1.0,
          "format": "%.2f"
        }
      ]
    },
    {
      "title": "Reference color pattern",
      "controls": [
        {
          "key": "texture_color_band_strength",
          "label": "Blue/yellow/red/brown mix",
          "min": 0.0,
          "max": 1.0,
          "format": "%.2f"
        },
        {
          "key": "texture_color_band_scale",
          "label": "Color repeat scale",
          "min": 0.1,
          "max": 8.0,
          "format": "%.2f"
        },
        {
          "key": "texture_color_band_shift",
          "label": "Color phase",
          "min": -12.0,
          "max": 12.0,
          "format": "%.2f"
        },
        {
          "key": "texture_saturation",
          "label": "Saturation",
          "min": 0.0,
          "max": 2.5,
          "format": "%.2f"
        },
        {
          "key": "texture_contrast",
          "label": "Contrast",
          "min": 0.25,
          "max": 2.5,
          "format": "%.2f"
        }
      ]
    }
  ],
