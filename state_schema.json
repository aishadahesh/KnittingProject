{
  "workflow_stages": [
    {
      "title": "Align",
      "subtitle": "Match the model and reference image in the viewport."
    },
    {
      "title": "Pattern",
      "subtitle": "Set bitmap size, row visibility, and stitch pattern."
    },
    {
      "title": "Geometry",
      "subtitle": "Tune physical knitting parameters manually."
    },
    {
      "title": "Material",
      "subtitle": "Choose opacity and yarn colors."
    },
    {
      "title": "Texture",
      "subtitle": "Tune the yarn texture tint and see it live."
    },
    {
      "title": "Lighting",
      "subtitle": "Adjust scene lighting and see it live."
    },
    {
      "title": "Spline",
      "subtitle": "Refine control points when the coarse shape is close."
    },
    {
      "title": "Review",
      "subtitle": "Render, save, load, and run the existing optimizer."
    }
  ],
  "texture_param_keys": [
    "texture_ridge_strength",
