{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Knitting App (uv)",
      "type": "shell",
      "command": "uv",
      "args": [
        "run",
        "python",
        "guided_workflow_app.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
